# ────────────────────────────────────────────────
# NotiFi-Server — 환경 변수 예시
# 이 파일을 .env 로 복사한 뒤 실제 값으로 채우세요.
# .env 는 git 추적에서 제외됩니다.
# ────────────────────────────────────────────────

# PostgreSQL
DB_NAME=notifi
DB_USERNAME=notifi
DB_PASSWORD=notifi
DB_URL=jdbc:postgresql://localhost:5432/notifi

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# 내부 API 인증 키 (AI 서버 → Spring, X-Internal-Key 헤더)
INTERNAL_API_KEY=change-me-before-deploy

# JWT
JWT_SECRET=your-secret-key-must-be-at-least-32-characters-long!
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=604800

# 프로파일 (local | prod)
SPRING_PROFILES_ACTIVE=local

# CORS 허용 origin (prod 에선 실제 도메인으로 교체, 쉼표 구분)
CORS_ALLOWED_ORIGINS=*
